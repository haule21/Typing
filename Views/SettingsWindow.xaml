<Window x:Class="TypingApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Typing v0.1 Settings" Height="380" Width="300" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="10">
        <Label Content="Typing Delay (ms):"/>
        <TextBox Name="txtDelay" Height="25" VerticalContentAlignment="Center"/>
        
        <Label Content="Paste Hotkey:" Margin="0,10,0,0"/>
        <StackPanel Orientation="Horizontal">
            <TextBox Name="txtHotkey" Width="150" Height="25" VerticalContentAlignment="Center" IsReadOnly="True" Focusable="False" Margin="0,0,10,0"/>
            <Button Name="btnChangeHotkey" Content="Change" Width="60" Height="25" Click="BtnChangeHotkey_Click"/>
        </StackPanel>
        <TextBlock Name="lblStatus" Foreground="Gray" Margin="0,5,0,0" FontStyle="Italic"/>

        <Label Content="입력 필터링:" Margin="0,10,0,0" FontWeight="Bold"/>
        <CheckBox x:Name="chkIgnoreTabs" Content="Tab(\t) 입력 제외" Margin="5,5,0,0"/>
        <CheckBox x:Name="chkIgnoreNewlines" Content="줄바꿈(\n) 입력 제외" Margin="5,5,0,0"/>

        <Label Content="실행 지연:" Margin="0,10,0,0" FontWeight="Bold"/>
        <StackPanel Orientation="Horizontal" Margin="5,5,0,0">
            <Label Content="입력 전 대기 시간:" VerticalContentAlignment="Center" Padding="0,0,5,0"/>
            <TextBox x:Name="txtExecutionDelay" Width="40" Height="25" VerticalContentAlignment="Center" Text="0"/>
            <Label Content="초 (0~10)" VerticalContentAlignment="Center" Foreground="Gray"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Name="btnSave" Content="Save" Width="70" Margin="0,0,10,0" Height="25" Click="BtnSave_Click"/>
            <Button Name="btnCancel" Content="Cancel" Width="70" Height="25" Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
