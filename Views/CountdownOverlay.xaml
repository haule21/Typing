<Window x:Class="TypingApp.Views.CountdownOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CountdownOverlay" Height="150" Width="150"
        WindowStyle="None" AllowsTransparency="True" Topmost="True" Background="Transparent" ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Grid>
        <Ellipse Fill="#80000000" Width="100" Height="100"/>
        <TextBlock x:Name="txtCountdown" Text="3" FontSize="50" FontWeight="Bold" Foreground="White" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
